# =============================================================================
# SmartFinance AI Bot — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in the real values before running the app.
# NEVER commit your actual .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Telegram Bot
# -----------------------------------------------------------------------------
# Obtain from @BotFather on Telegram (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# -----------------------------------------------------------------------------
# Google Gemini AI
# -----------------------------------------------------------------------------
# Obtain from Google AI Studio (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# -----------------------------------------------------------------------------
# Flask / Dashboard Session Security
# -----------------------------------------------------------------------------
# A long, random string used to sign session cookies.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=your_random_session_secret_here

# -----------------------------------------------------------------------------
# Google Sheets Integration (Service Account)
# -----------------------------------------------------------------------------
# Base64-encoded content of your Google service account JSON key file.
# Encode with: base64 -w 0 credentials.json
# Keep this value secret — it grants access to your Google account.
GOOGLE_CREDENTIALS_BASE64=your_base64_encoded_google_credentials_here

# -----------------------------------------------------------------------------
# Groq API (reserved for future use)
# -----------------------------------------------------------------------------
# Obtain from https://console.groq.com/keys
# Currently required by config/settings.py but not actively used.
GROQ_API_KEY=your_groq_api_key_here

# -----------------------------------------------------------------------------
# Dashboard Public URL
# -----------------------------------------------------------------------------
# The publicly accessible URL where the FastAPI dashboard is hosted.
# Example: https://smartfinanceai--bottelegramwebs.replit.app
DASHBOARD_URL=https://your-dashboard-url-here.replit.app
